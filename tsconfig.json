{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "ESNext.Decorators"],
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "strictPropertyInitialization": false,
  },
}
